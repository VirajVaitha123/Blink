# ---------- Backend ----------
ENVIRONMENT=development
DEBUG=false

# Postgres connection. Local docker default below; for Azure use the flexible-server
# connection string and switch DB_SSLMODE to "require".
DATABASE_URL=postgresql://blink:blink@localhost:5432/blink
DB_SSLMODE=prefer

# Pool tuning (defaults are fine; override in prod if needed)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Used for CORS in production — leave unset locally.
# FRONTEND_URL=https://blink.example.com

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ElevenLabs text-to-speech for scanner voice cues ("Starting", "Opened menu").
# The /api/tts route reads this server-side; never exposed to the browser.
# Optional: override the default voice (Rachel, 21m00Tcm4TlvDq8ikWAM).
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
